{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "types": [
      "vitest/globals"
    ],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@mobile-contracts": [
        "./packages/mobile-contracts/src/index.ts"
      ],
      "@mobile-contracts/*": [
        "./packages/mobile-contracts/src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "apps/medusa/**/*",
    "apps/mobile/**/*",
    "node_modules",
    "supabase/functions/**/*",
    "debug/**/*",
    "tmp/**/*"
  ]
}