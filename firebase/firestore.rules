rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // trainer_profiles
    match /trainer_profiles/{userId} {
      allow read: if isOwner(userId);
      allow write: if false; // Only via Admin SDK/Functions for now
    }

    // member_profiles
    match /member_profiles/{profileId} {
      allow read: if isAuthenticated() && resource.data.supabase_user_id == request.auth.uid;
      allow write: if false;
    }

    // member_plan_snapshots
    match /member_plan_snapshots/{snapshotId} {
      allow read: if isAuthenticated() && 
        get(/databases/$(database)/documents/member_profiles/$(resource.data.member_id)).data.supabase_user_id == request.auth.uid;
      allow write: if false;
    }

    // site_settings
    match /site_settings/{settingId} {
      allow read: if true; // Public settings
      allow write: if false;
    }

    // user_roles (RBAC)
    match /user_roles/{roleId} {
      allow read: if isAuthenticated();
      allow write: if false; // Cloud Functions only
    }

    // leads
    match /leads/{leadId} {
      allow create: if true; // Public lead capture
      allow read, update: if isAdmin();
    }

    // marketing_testimonials
    match /marketing_testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // pickup_requests
    match /pickup_requests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.customer_id == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // Helper for admin checks
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/user_roles/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
